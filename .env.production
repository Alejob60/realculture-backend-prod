# Puerto personalizado para evitar colisiones entre microservicios
PORT=3001

# Entorno productivo
NODE_ENV=production

# PostgreSQL (ajusta con tu host, usuario y contraseña reales)
DATABASE_URL=postgresql://adminrealculture:AQUI_TU_PASSWORD@realculture-db.postgres.database.azure.com:5432/realculture

# JWT
JWT_SECRET=super_jwt_realculture_2025

# CORS (ajústalo si tu frontend es otro dominio)
CORS_ORIGIN=https://realculture.com

# BACKEND PRINCIPAL URL (para callbacks, notificaciones, etc.)
MAIN_BACKEND_URL=https://realculture-backend.azurewebsites.net

# Azure OpenAI (DALL·E, GPT, Sora)
AZURE_OPENAI_API_KEY=sk-AQUI_VA_TU_APIKEY
AZURE_OPENAI_IMAGE_ENDPOINT=https://realculture-openai.eastus2.inference.azure.com
AZURE_OPENAI_IMAGE_DEPLOYMENT=dalle3-deploy
AZURE_OPENAI_IMAGE_API_VERSION=2024-02-15-preview

AZURE_SORA_API_KEY=sk-AQUI_TU_APIKEY_SORA
AZURE_SORA_URL=https://labsc-m9j5kbl9-eastus2.openai.azure.com/openai/deployments/soramodel
AZURE_SORA_DEPLOYMENT=soramodel
AZURE_SORA_API_VERSION=2025-02-15-preview

# Azure TTS
AZURE_TTS_API_KEY=sk-AQUI_TU_APIKEY_TTS
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=Nova
AZURE_TTS_API_VERSION=2025-03-20
AZURE_TTS_ENDPOINT=https://eastus.tts.speech.microsoft.com

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=realculturestorage;AccountKey=AQUI_LA_LLAVE;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=realculturestorage
AZURE_STORAGE_KEY=AQUI_LA_LLAVE
AZURE_STORAGE_CONTAINER_NAME=audio

# Seguridad: Token expiración y planes
JWT_EXPIRES_IN=7d
DEFAULT_PLAN=FREE
FREE_CREDITS=25

# Otros
FRONTEND_URL=https://realculture.com
